# Stage 1: Build the application in golang-alpine




FROM golang:1.26-alpine AS builder

# Set the working directory inside the container
WORKDIR /src

# Copy go.mod and go.sum to the working directory
COPY go.mod go.sum ./
RUN go mod download

# Install dependencies
RUN apk add --no-cache ca-certificates tzdata

# Copy the entire source code to the working directory
COPY . . 

# Build the application with CGO disabled and static linking
RUN CGO_ENABLED=0 GOOS=linux go build \
	-trimpath \
	-ldflags='-s -w -extldflags "-static"' \
	-o /out/melissa-bot cmd/melissa-bot/main.go
    
# Stage 2: Create a minimal image with the built application
FROM scratch

# Copy the built application from the builder stage
COPY --from=builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
COPY --from=builder /usr/share/zoneinfo /usr/share/zoneinfo
COPY --from=builder /out/melissa-bot /melissa-bot

# Set the entry point to run the application
ENTRYPOINT ["/melissa-bot"]
